const swiper = new Swiper('.swiper', {
    direction: 'vertical',
    speed: 1000,
    mousewheel: true,
    grabCursor: true,
    
    on: {
        slideChange: function () {
            let bg = document.querySelector('.fixed-background');
            
            // Adjust background zoom slightly as she scrolls for a "feel"
            let zoom = 1 + (this.activeIndex * 0.03);
            bg.style.transform = `scale(${zoom})`;
            
            // On slide 1, keep background clear, on others keep it slightly darker
            if (this.activeIndex === 0) {
                bg.style.filter = "blur(0px) brightness(0.8)";
            } else {
                bg.style.filter = "blur(5px) brightness(0.6)";
            }
        },
    },
});
